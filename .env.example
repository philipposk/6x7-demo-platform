# Auto-injected on Vercel by the linked 6x7 Supabase project.
# For local dev, copy to .env.local and fill from Supabase → Project → API.
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_DEMO=price_...          # Stripe → Products → Demo Pro price id
STRIPE_PRICE_GLOBAL=price_...        # Stripe → Products → 6x7 Pro price id
STRIPE_WEBHOOK_SECRET=whsec_...      # Stripe → Developers → Webhooks → signing secret

# Needed by the Stripe webhook to write public.subscriptions (server-only).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Render trigger — dispatches the GitHub Actions workflow in the worker repo.
GITHUB_DISPATCH_TOKEN=<fine-grained PAT with actions:write on the worker repo>
GITHUB_WORKER_REPO=philipposk/6x7-demo-worker
GITHUB_WORKER_REF=main
